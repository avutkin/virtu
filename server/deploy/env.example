# Copy to server/deploy/.env on the box and fill in real values.
# This file holds secrets — the setup script chmods .env to 600 and it is
# gitignored. NEVER commit the real .env.

# --- PostgreSQL (runs on localhost, never exposed to the internet) ---
# Use a long random password: `openssl rand -base64 24`
DB_PASSWORD=CHANGE_ME_long_random_password
DATABASE_URL=postgresql://wythin:CHANGE_ME_long_random_password@localhost:5432/wythin

# --- OpenAI (server-side only; the key never ships inside the app) ---
OPENAI_API_KEY=sk-...

# --- Optional: shared API key the app must send as `X-API-Key` ---
# Turn on app<->server authentication (see README "Authentication"). Generate
# with `openssl rand -hex 32`. Leave unset to disable the check.
# API_KEY=
